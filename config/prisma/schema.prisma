generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================================
// Enums — frozen as of Milestone 3.1. Full purpose/values/default/future
// notes for every enum below live in docs/36_DATABASE_FREEZE.md "Enum
// Reference"; do not add or change a value here without updating that
// section in the same change.
//
// Per 33_PRISMA_MODELING_GUIDE.md: fixed, stable value sets become enums;
// open-ended/extensible text fields (event_type, activity_type, action,
// namespace/key, ad placement position, role scope, permission group,
// notification type) intentionally stay String — see 36_DATABASE_FREEZE.md
// for why each of those was deliberately not enumerated.
// =====================================================================

/// Editorial lifecycle shared by Articles, ArticleRevisions, and Pages.
/// Source: 20_BACKEND_ARCHITECTURE.md §14 Editorial Workflow (frozen).
enum ContentStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
  DELETED

  @@map("content_status")
}

/// Frozen V1 enum — see docs/36_DATABASE_FREEZE.md "Enum Reference" for purpose, allowed values, default, and future-expansion notes.
enum ArticleVisibility {
  PUBLIC
  PRIVATE
  UNLISTED

  @@map("article_visibility")
}

