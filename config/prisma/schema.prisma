// =====================================================================
// Identity & Security
// =====================================================================

model User {
  id             String     @id @default(uuid()) @db.Uuid
  tenantId       String?    @map("tenant_id") @db.Uuid
  siteId         String?    @map("site_id") @db.Uuid
  email          String
  username       String?
  displayName    String?    @map("display_name")
  passwordHash   String?    @map("password_hash")
  status         UserStatus @default(PENDING)
  profileImageId String?    @map("profile_image_id") @db.Uuid
  lastLoginAt    DateTime?  @map("last_login_at") @db.Timestamptz(6)
  metadata       Json?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant       Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  site         Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)
  profileImage MediaAsset? @relation("UserProfileImage", fields: [profileImageId], references: [id], onDelete: SetNull)

  authors            Author[]
  sessions           Session[]
  refreshTokens      RefreshToken[]
  passwordResets     PasswordResetToken[]
  emailVerifications EmailVerification[]
  userRoles          UserRole[]
  comments           Comment[]
  uploadedMedia      MediaAsset[]         @relation("MediaUploadedBy")
  notifications      Notification[]
  aiJobsRequested    AiJob[]              @relation("AiJobRequestedBy")
  auditLogs          AuditLog[]
  activityLogs       ActivityLog[]
  analyticsEvents    AnalyticsEvent[]

  @@index([siteId, email])
  @@index([siteId])
  @@map("users")
}

model Session {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  siteId          String?   @map("site_id") @db.Uuid
  refreshTokenId  String?   @map("refresh_token_id") @db.Uuid
  ipAddress       String?   @map("ip_address")
  userAgent       String?   @map("user_agent")
  deviceName      String?   @map("device_name")
  /// Metadata only (Milestone 4.1 §3) — no user-agent parsing library wired yet.
  browser         String?   @map("browser")
  /// Metadata only (Milestone 4.1 §3) — no user-agent parsing library wired yet.
  operatingSystem String?   @map("operating_system")
  /// Metadata only (Milestone 4.1 §3) — no geo-IP lookup wired yet.
  country         String?   @map("country")
  /// Metadata only (Milestone 4.1 §3) — no geo-IP lookup wired yet.
  city            String?   @map("city")
  /// Whether this session was created via "remember me" (longer expiry).
  rememberMe      Boolean   @default(false) @map("remember_me")
  lastSeenAt      DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  site         Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  refreshToken RefreshToken? @relation(fields: [refreshTokenId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([refreshTokenId])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  tokenHash     String    @map("token_hash")
  issuedAt      DateTime  @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedReason String?   @map("revoked_reason")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([tokenHash])
  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @map("token_hash")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt      DateTime? @map("used_at") @db.Timestamptz(6)
  requestedAt DateTime  @default(now()) @map("requested_at") @db.Timestamptz(6)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerification {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @map("token_hash")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  verifiedAt  DateTime? @map("verified_at") @db.Timestamptz(6)
  requestedAt DateTime  @default(now()) @map("requested_at") @db.Timestamptz(6)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("email_verifications")
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  name        String
  description String?
  /// Open-ended scope descriptor (e.g. site/section scoping) — not a fixed documented set.
  scope       String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  resource    String
  action      String
  description String?
  /// Open-ended grouping label — not a fixed documented set.
  group       String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  rolePermissions RolePermission[]

  @@index([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  /// Optional section/site-level scoping payload for this assignment.
  scope      Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// =====================================================================
// Tenant & Site
// =====================================================================

model Tenant {
  id       String       @id @default(uuid()) @db.Uuid
  name     String
  slug     String
  status   TenantStatus @default(ACTIVE)
  settings Json?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  sites         Site[]
  users         User[]
  roles         Role[]
  notifications Notification[]
  settingsRows  Setting[]
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]

  @@index([slug])
  @@map("tenants")
}

model Site {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  name        String
  slug        String
  domain      String
  locale      String?
  timezone    String?
  status      SiteStatus @default(ACTIVE)
  theme       Json?
  seoDefaults Json?      @map("seo_defaults")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  users           User[]
  sessions        Session[]
  authors         Author[]
  categories      Category[]
  tags            Tag[]
  articles        Article[]
  mediaAssets     MediaAsset[]
  mediaFolders    MediaFolder[]
  seoMeta         SeoMeta[]
  redirects       Redirect[]
  sitemaps        Sitemap[]
  ads             Ad[]
  analyticsEvents AnalyticsEvent[]
  searchLogs      SearchLog[]
  settingsRows    Setting[]
  aiJobs          AiJob[]
  aiPrompts       AiPrompt[]
  auditLogs       AuditLog[]
  activityLogs    ActivityLog[]
  menus           Menu[]
  pages           Page[]

  @@index([tenantId, slug])
  @@index([domain])
  @@map("sites")
}

// =====================================================================
// Content
// =====================================================================

model Author {
  id             String  @id @default(uuid()) @db.Uuid
  siteId         String  @map("site_id") @db.Uuid
  userId         String? @map("user_id") @db.Uuid
  penName        String  @map("pen_name")
  bio            String?
  profileImageId String? @map("profile_image_id") @db.Uuid
  socialLinks    Json?   @map("social_links")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  site         Site        @relation(fields: [siteId], references: [id], onDelete: Restrict)
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  profileImage MediaAsset? @relation("AuthorProfileImage", fields: [profileImageId], references: [id], onDelete: SetNull)

  articles         Article[]
  articleRevisions ArticleRevision[]

  @@index([siteId, penName])
  @@index([siteId])
  @@index([userId])
  @@map("authors")
}

model Category {
  id          String         @id @default(uuid()) @db.Uuid
  siteId      String         @map("site_id") @db.Uuid
  parentId    String?        @map("parent_id") @db.Uuid
  name        String
  slug        String
  description String?
  status      CategoryStatus @default(ACTIVE)
  seoMetaId   String?        @map("seo_meta_id") @db.Uuid
  sortOrder   Int?           @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  site     Site       @relation(fields: [siteId], references: [id], onDelete: Restrict)
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryHierarchy")
  seoMeta  SeoMeta?   @relation(fields: [seoMetaId], references: [id], onDelete: SetNull)

  articles Article[]

  @@index([siteId, slug])
  @@index([parentId])
  @@map("categories")
}

model Tag {
  id          String  @id @default(uuid()) @db.Uuid
  siteId      String  @map("site_id") @db.Uuid
  name        String
  slug        String
  description String?
  synonyms    Json?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  site        Site         @relation(fields: [siteId], references: [id], onDelete: Restrict)
  articleTags ArticleTag[]

  @@index([siteId, slug])
  @@map("tags")
}

model Article {
  id                String            @id @default(uuid()) @db.Uuid
  siteId            String            @map("site_id") @db.Uuid
  authorId          String            @map("author_id") @db.Uuid
  primaryCategoryId String?           @map("primary_category_id") @db.Uuid
  title             String
  subtitle          String?
  slug              String
  summary           String?
  body              Json
  status            ContentStatus     @default(DRAFT)
  publishedAt       DateTime?         @map("published_at") @db.Timestamptz(6)
  scheduledAt       DateTime?         @map("scheduled_at") @db.Timestamptz(6)
  canonicalUrl      String?           @map("canonical_url")
  visibility        ArticleVisibility @default(PUBLIC)
  language          String
  locale            String
  seoMetaId         String?           @map("seo_meta_id") @db.Uuid
  featuredMediaId   String?           @map("featured_media_id") @db.Uuid
  readingTime       Int?              @map("reading_time")
  wordCount         Int?              @map("word_count")
  notes             String?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  site            Site        @relation(fields: [siteId], references: [id], onDelete: Restrict)
  author          Author      @relation(fields: [authorId], references: [id], onDelete: Restrict)
  primaryCategory Category?   @relation(fields: [primaryCategoryId], references: [id], onDelete: SetNull)
  seoMeta         SeoMeta?    @relation(fields: [seoMetaId], references: [id], onDelete: SetNull)
  featuredMedia   MediaAsset? @relation("ArticleFeaturedMedia", fields: [featuredMediaId], references: [id], onDelete: SetNull)

  revisions ArticleRevision[]
  tags      ArticleTag[]
  media     ArticleMedia[]
  comments  Comment[]

  @@index([siteId, slug])
  @@index([siteId, status, publishedAt])
  @@index([authorId])
  @@map("articles")
}

model ArticleRevision {
  id        String        @id @default(uuid()) @db.Uuid
  articleId String        @map("article_id") @db.Uuid
  version   Int
  body      Json
  title     String
  summary   String?
  status    ContentStatus
  authorId  String        @map("author_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  comment   String?

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  Author  @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@unique([articleId, version])
  @@index([articleId])
  @@map("article_revisions")
}

model ArticleTag {
  articleId String  @map("article_id") @db.Uuid
  tagId     String  @map("tag_id") @db.Uuid
  primary   Boolean @default(false)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
  @@map("article_tags")
}

model ArticleMedia {
  articleId    String  @map("article_id") @db.Uuid
  mediaAssetId String  @map("media_asset_id") @db.Uuid
  position     Int?
  role         String?
  caption      String?

  article    Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

