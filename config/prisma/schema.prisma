model MediaAsset {
  id         String      @id @default(uuid()) @db.Uuid
  siteId     String      @map("site_id") @db.Uuid
  uploadedBy String      @map("uploaded_by") @db.Uuid
  type       MediaType
  storageKey String      @map("storage_key")
  mimeType   String      @map("mime_type")
  filesize   BigInt
  width      Int?
  height     Int?
  duration   Int?
  altText    String?     @map("alt_text")
  caption    String?
  credit     String?
  metadata   Json?
  status     MediaStatus @default(PROCESSING)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  site     Site @relation(fields: [siteId], references: [id], onDelete: Restrict)
  uploader User @relation("MediaUploadedBy", fields: [uploadedBy], references: [id], onDelete: Restrict)

  profileOfUsers     User[]         @relation("UserProfileImage")
  profileOfAuthors   Author[]       @relation("AuthorProfileImage")
  featuredInArticles Article[]      @relation("ArticleFeaturedMedia")
  articleLinks       ArticleMedia[]

  @@index([siteId, storageKey])
  @@index([siteId])
  @@index([uploadedBy])
  @@map("media_assets")
}

model MediaFolder {
  id       String  @id @default(uuid()) @db.Uuid
  siteId   String  @map("site_id") @db.Uuid
  parentId String? @map("parent_id") @db.Uuid
  name     String
  slug     String

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?   @map("deleted_by") @db.Uuid

  site     Site          @relation(fields: [siteId], references: [id], onDelete: Restrict)
  parent   MediaFolder?  @relation("MediaFolderHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children MediaFolder[] @relation("MediaFolderHierarchy")

  @@index([siteId, slug])
  @@index([parentId])
  @@map("media_folders")
}

