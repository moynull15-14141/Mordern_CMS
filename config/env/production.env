NODE_ENV=production
PORT=4000
APP_NAME=sportingspy-backend
APP_VERSION=0.1.0
API_PREFIX=api/v1
CORS_ORIGIN=https://sportingspy.com,https://admin.sportingspy.com
THROTTLE_TTL=60
THROTTLE_LIMIT=100

DATABASE_URL=postgresql://prod-db:5432/sportingspy_prod

JWT_SECRET=change-me-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-production-refresh
JWT_REFRESH_EXPIRES_IN=7d
AUTH_REMEMBER_ME_EXPIRES_IN=30d
AUTH_PASSWORD_RESET_EXPIRES_IN=1h
AUTH_EMAIL_VERIFICATION_EXPIRES_IN=24h

REDIS_URL=redis://prod-redis:6379
CACHE_PROVIDER=redis

STORAGE_PROVIDER=r2
STORAGE_ENDPOINT=https://storage.example.com
STORAGE_REGION=auto
STORAGE_BUCKET=sportingspy-prod
STORAGE_ACCESS_KEY_ID=change-me-production
STORAGE_SECRET_ACCESS_KEY=change-me-production

AI_ENABLED=false
AI_PROVIDER=openai
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=
AI_TIMEOUT_MS=30000
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048
AI_RETRY_ATTEMPTS=2

SEARCH_ENABLED=false
SEARCH_ENGINE=database
SEARCH_HOST=
SEARCH_API_KEY=
SEARCH_TIMEOUT_MS=5000

FEATURE_AI_ENABLED=false
FEATURE_COMMENTS_ENABLED=true
FEATURE_RSS_ENABLED=false
FEATURE_SEARCH_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_MEDIA_ENABLED=true
