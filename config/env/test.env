NODE_ENV=test
PORT=4000
APP_NAME=sportingspy-backend
APP_VERSION=0.1.0
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
THROTTLE_TTL=60
THROTTLE_LIMIT=100

DATABASE_URL=postgresql://localhost:5432/sportingspy_test

JWT_SECRET=test-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test-secret-refresh
JWT_REFRESH_EXPIRES_IN=7d
AUTH_REMEMBER_ME_EXPIRES_IN=30d
AUTH_PASSWORD_RESET_EXPIRES_IN=1h
AUTH_EMAIL_VERIFICATION_EXPIRES_IN=24h

REDIS_URL=redis://localhost:6379
CACHE_PROVIDER=redis

STORAGE_PROVIDER=r2
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_BUCKET=sportingspy-test
STORAGE_ACCESS_KEY_ID=test
STORAGE_SECRET_ACCESS_KEY=test

AI_ENABLED=false
AI_PROVIDER=openai
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=
AI_TIMEOUT_MS=30000
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048
AI_RETRY_ATTEMPTS=2

SEARCH_ENABLED=false
SEARCH_ENGINE=database
SEARCH_HOST=
SEARCH_API_KEY=
SEARCH_TIMEOUT_MS=5000

FEATURE_AI_ENABLED=false
FEATURE_COMMENTS_ENABLED=true
FEATURE_RSS_ENABLED=false
FEATURE_SEARCH_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_MEDIA_ENABLED=true
