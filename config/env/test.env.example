# Modern CMS — test environment TEMPLATE (stabilization patch, post-Final-Backend-Audit)
# Generated from apps/backend/src/config/env.validation.ts + registerAs() factories.
#
# This file IS meant to be committed — it contains no real secrets (every
# sensitive value is a REPLACE_ME placeholder). It closes the CI-environment
# gap the Final Backend Architecture Audit flagged: config/env/*.env is
# gitignored, so a fresh CI checkout has no test.env at all. Copy this file
# to config/env/test.env (gitignored) and fill in the REPLACE_ME values for
# local development, or wire a CI step to do the same from repository
# secrets before running tests that boot the real ConfigModule/AppModule
# (today's test suite does not require this — no spec currently bootstraps
# AppModule against a live database — but any future one will).
#
# Lines marked REPLACE_ME are secrets that must be filled in manually — never commit real values.

NODE_ENV=test
PORT=4001
APP_NAME=sportingspy-backend
APP_VERSION=0.1.0
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Database (use a dedicated test database/schema — do not point at production data) ---
DATABASE_URL=REPLACE_ME_TEST_DATABASE_URL

# --- JWT / Auth ---
JWT_SECRET=REPLACE_ME_JWT_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_ME_JWT_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=7d
AUTH_REMEMBER_ME_EXPIRES_IN=30d
AUTH_PASSWORD_RESET_EXPIRES_IN=1h
AUTH_EMAIL_VERIFICATION_EXPIRES_IN=24h

# --- Cache ---
REDIS_URL=REPLACE_ME_REDIS_URL
CACHE_PROVIDER=redis

# --- Storage ---
STORAGE_PROVIDER=REPLACE_ME_STORAGE_PROVIDER
STORAGE_ENDPOINT=REPLACE_ME_STORAGE_ENDPOINT
STORAGE_REGION=REPLACE_ME_STORAGE_REGION
STORAGE_BUCKET=REPLACE_ME_STORAGE_BUCKET
STORAGE_ACCESS_KEY_ID=REPLACE_ME_STORAGE_ACCESS_KEY_ID
STORAGE_SECRET_ACCESS_KEY=REPLACE_ME_STORAGE_SECRET_ACCESS_KEY

# --- AI (must remain disabled) ---
AI_ENABLED=false
AI_PROVIDER=openai
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=
AI_TIMEOUT_MS=30000
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048
AI_RETRY_ATTEMPTS=2

# --- Search ---
SEARCH_ENABLED=false
SEARCH_ENGINE=database
SEARCH_HOST=
SEARCH_API_KEY=
SEARCH_TIMEOUT_MS=5000

# --- Feature flags ---
FEATURE_AI_ENABLED=false
FEATURE_COMMENTS_ENABLED=true
FEATURE_RSS_ENABLED=true
FEATURE_SEARCH_ENABLED=true
FEATURE_ANALYTICS_ENABLED=false
FEATURE_MEDIA_ENABLED=true
